# Automation Server - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- App ---
APP_NAME=automation-server
APP_PORT=3000
APP_ENV=development

# --- MySQL 8 ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=automation_server

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- JWT ---
JWT_SECRET=change-me-to-random-string

# --- WhatsApp ---
WHATSAPP_SESSION_PATH=./sessions

# --- Email SMTP ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- AI Service (Python, optional) ---
AI_SERVICE_URL=http://localhost:5000
